/* ==================== 全局样式 ==================== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background-color: #f0f2f5;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.5;
}

/* ==================== 色彩变量 ==================== */
/* 主题色 */
.text-primary { color: #2563eb; }
.text-white { color: #ffffff; }
.text-gray { color: #64748b; }
.text-red { color: #dc2626; }
.text-orange { color: #ea580c; }
.text-yellow { color: #d97706; }
.text-green { color: #059669; }
.text-blue { color: #2563eb; }

.bg-primary { background-color: #2563eb; }
.bg-dark { background-color: #0f172a; }
.bg-white { background-color: #ffffff; }

/* ==================== 通用组件 ==================== */
.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* ==================== 按钮 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  margin-top: 16rpx;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #2563eb, #1e40af);
  color: #ffffff;
}

.btn-success {
  background: linear-gradient(135deg, #059669, #10b981);
  color: #ffffff;
}

.btn-warning {
  background: linear-gradient(135deg, #d97706, #f59e0b);
  color: #ffffff;
}

.btn-danger {
  background: linear-gradient(135deg, #dc2626, #ef4444);
  color: #ffffff;
}

.btn-outline {
  background: #ffffff;
  color: #2563eb;
  border: 2rpx solid #2563eb;
}

.btn-ai {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: #ffffff;
}

.btn-large {
  height: 100rpx;
  font-size: 34rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

/* ==================== 风险等级 ==================== */
.risk-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  border-radius: 16rpx;
  color: #ffffff;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.risk-extreme {
  background: linear-gradient(135deg, #dc2626, #f87171);
}

.risk-high {
  background: linear-gradient(135deg, #ea580c, #fb923c);
}

.risk-mid {
  background: linear-gradient(135deg, #d97706, #fbbf24);
}

.risk-low {
  background: linear-gradient(135deg, #2563eb, #60a5fa);
}

.risk-level-text {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.risk-sub-text {
  font-size: 24rpx;
  opacity: 0.9;
}

/* ==================== 列表 ==================== */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
}

.list-item-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.list-item-arrow {
  color: #cbd5e1;
  font-size: 28rpx;
}

/* ==================== 标签 ==================== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-red {
  background: #fef2f2;
  color: #dc2626;
}

.tag-orange {
  background: #fff7ed;
  color: #ea580c;
}

.tag-green {
  background: #f0fdf4;
  color: #059669;
}

.tag-blue {
  background: #eff6ff;
  color: #2563eb;
}

.tag-gray {
  background: #f1f5f9;
  color: #64748b;
}

/* ==================== Tab 切换 ==================== */
.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #64748b;
  border-radius: 8rpx;
}

.tab-item.active {
  background: #2563eb;
  color: #ffffff;
  font-weight: 600;
}

/* ==================== 表单 ==================== */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-label .required {
  color: #dc2626;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus,
.form-input-focus {
  border-color: #2563eb;
  background: #ffffff;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 80rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ==================== 加载 ==================== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-box {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  font-size: 28rpx;
  color: #475569;
  margin-top: 20rpx;
}

/* ==================== 统计格子 ==================== */
.stat-grid {
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 50%;
  padding: 16rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* ==================== 分割线 ==================== */
.divider {
  height: 1rpx;
  background: #f1f5f9;
  margin: 20rpx 0;
}
