/* AI识别提示条 */
.ai-hint-bar {
  display: flex;
  align-items: center;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 24rpx;
}

.ai-hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.ai-hint-text {
  font-size: 26rpx;
  color: #1d4ed8;
  font-weight: 500;
}

/* AI填写字段标签 */
.ai-field-tag {
  display: inline-block;
  font-size: 18rpx;
  background: #2563eb;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
  font-weight: 600;
  vertical-align: middle;
}

/* AI填写字段高亮 */
.ai-filled {
  background: #eff6ff !important;
  border-color: #93c5fd !important;
}

/* 定位模块 */
.loc-display {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #f0fdf4;
  border: 1rpx solid #86efac;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.loc-empty {
  background: #f8fafc;
  border-color: #e2e8f0;
}

.loc-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.loc-text {
  flex: 1;
  font-size: 26rpx;
  color: #166534;
  word-break: break-all;
}

.loc-text-empty {
  font-size: 26rpx;
  color: #94a3b8;
}

.loc-clear {
  font-size: 28rpx;
  color: #94a3b8;
  padding: 0 8rpx;
}

.loc-actions {
  display: flex;
  gap: 16rpx;
}

.loc-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.loc-btn-gps {
  background: #eff6ff;
  color: #2563eb;
  border: 1rpx solid #bfdbfe;
}

.loc-btn-map {
  background: #f0fdf4;
  color: #059669;
  border: 1rpx solid #86efac;
}

.loc-btn-loading {
  opacity: 0.6;
}

.loc-btn:active {
  opacity: 0.75;
}
