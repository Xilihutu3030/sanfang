<view class="container">
  <!-- 气象摘要 -->
  <view class="card" wx:if="{{weather}}">
    <view class="card-title">
      <text class="card-title-icon">🌤️</text>
      <text>当前气象</text>
    </view>
    <view class="weather-row">
      <text class="text-red">{{weather.warning}}</text>
      <text> | 1h: {{weather.rain1h}}mm</text>
      <text> | 24h: {{weather.rain24h}}mm</text>
      <text> | 预报: {{weather.forecast6h}}</text>
    </view>
  </view>

  <!-- 潮汐与海洋数据 -->
  <view class="card" wx:if="{{tideData}}">
    <view class="card-title">
      <text class="card-title-icon">🌊</text>
      <text>潮汐/海洋</text>
      <view class="tide-refresh" bindtap="refreshTide">刷新</view>
    </view>
    <view class="tide-grid">
      <view class="tide-item">
        <text class="tide-label">潮汐状态</text>
        <text class="tide-value">{{tideData.status}}</text>
      </view>
      <view class="tide-item">
        <text class="tide-label">当前潮位</text>
        <text class="tide-value">{{tideData.level}}</text>
      </view>
      <view class="tide-item">
        <text class="tide-label">浪高</text>
        <text class="tide-value">{{tideData.waveHeight}}</text>
      </view>
      <view class="tide-item">
        <text class="tide-label">涌浪</text>
        <text class="tide-value">{{tideData.swellHeight}}</text>
      </view>
      <view class="tide-item">
        <text class="tide-label">下次高潮</text>
        <text class="tide-value tide-value-sm">{{tideData.nextHigh}}</text>
      </view>
      <view class="tide-item">
        <text class="tide-label">海洋风险</text>
        <text class="tide-value {{tideData.marineRisk === '高' ? 'text-red' : (tideData.marineRisk === '中' ? 'text-orange' : '')}}">{{tideData.marineRisk}}</text>
      </view>
    </view>
  </view>

  <!-- 行政区域选择 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">📍</text>
      <text>行政区域</text>
      <view class="region-clear" wx:if="{{regionPath}}" bindtap="clearRegion">清除</view>
    </view>
    <!-- 级联选择器 -->
    <view class="region-selectors">
      <picker mode="selector" range="{{provinceList}}" range-key="name" value="{{provinceIdx}}" bindchange="onProvinceChange">
        <view class="region-pick {{provinceIdx >= 0 ? 'region-pick-active' : ''}}">
          {{provinceIdx >= 0 ? provinceList[provinceIdx].name : '选择省/直辖市'}}
          <text class="region-arrow">▾</text>
        </view>
      </picker>
      <picker mode="selector" range="{{cityList}}" range-key="name" value="{{cityIdx}}" bindchange="onCityChange" disabled="{{!cityList.length || _isMunicipality}}">
        <view class="region-pick {{cityIdx >= 0 ? 'region-pick-active' : ''}} {{(!cityList.length || _isMunicipality) ? 'region-pick-disabled' : ''}}">
          {{_isMunicipality ? '直辖市' : (cityIdx >= 0 ? cityList[cityIdx].name : '选择市/州')}}
          <text class="region-arrow">▾</text>
        </view>
      </picker>
      <picker mode="selector" range="{{districtList}}" range-key="name" value="{{districtIdx}}" bindchange="onDistrictChange" disabled="{{!districtList.length}}">
        <view class="region-pick {{districtIdx >= 0 ? 'region-pick-active' : ''}} {{!districtList.length ? 'region-pick-disabled' : ''}}">
          {{districtIdx >= 0 ? districtList[districtIdx].name : '选择区/县'}}
          <text class="region-arrow">▾</text>
        </view>
      </picker>
      <picker mode="selector" range="{{townList}}" range-key="name" value="{{townIdx}}" bindchange="onTownChange" disabled="{{!townList.length}}">
        <view class="region-pick {{townIdx >= 0 ? 'region-pick-active' : ''}} {{!townList.length ? 'region-pick-disabled' : ''}}">
          {{townIdx >= 0 ? townList[townIdx].name : '选择乡镇/街道'}}
          <text class="region-arrow">▾</text>
        </view>
      </picker>
    </view>
    <!-- 选中路径 -->
    <view class="region-info" wx:if="{{regionPath}}">
      <text class="region-path-text">{{regionPath}}</text>
      <view class="region-btns">
        <view class="region-btn" bindtap="flyToRegion">定位</view>
        <view class="region-btn {{showRegionBorder ? 'region-btn-active' : ''}}" bindtap="toggleRegionBorder">边界</view>
      </view>
    </view>
  </view>

  <!-- 地图圈选区域 -->
  <view class="card" style="padding: 0; overflow: hidden;">
    <!-- 操作工具栏 -->
    <view class="draw-toolbar">
      <view class="draw-left">
        <!-- 形状切换 -->
        <view class="shape-switch" wx:if="{{!polyPoints.length}}">
          <view class="shape-btn {{drawShape === 'rect' ? 'shape-active' : ''}}" bindtap="switchShape" data-shape="rect">▭ 矩形</view>
          <view class="shape-btn {{drawShape === 'circle' ? 'shape-active' : ''}}" bindtap="switchShape" data-shape="circle">○ 圆形</view>
        </view>
        <!-- 状态提示 -->
        <view class="draw-status">
          <text wx:if="{{!drawing && polyPoints.length === 0}}">选好形状后点击「开始圈选」</text>
          <text wx:if="{{drawing && tapPoints.length === 0}}">在地图上点击第一个点</text>
          <text wx:if="{{drawing && tapPoints.length === 1 && drawShape === 'rect'}}">再点一下确定矩形对角</text>
          <text wx:if="{{drawing && tapPoints.length === 1 && drawShape === 'circle'}}">再点一下确定圆的半径</text>
          <text wx:if="{{!drawing && polyPoints.length > 0}}" class="text-green">区域已选定 ✓</text>
        </view>
      </view>
      <view class="draw-actions">
        <view class="draw-btn draw-btn-reset" wx:if="{{polyPoints.length > 0}}" bindtap="resetPolygon">重置</view>
        <view class="draw-btn draw-btn-primary" wx:if="{{!drawing && polyPoints.length === 0}}" bindtap="startDraw">开始圈选</view>
        <view class="draw-btn draw-btn-cancel" wx:if="{{drawing}}" bindtap="cancelDraw">取消</view>
      </view>
    </view>

    <!-- 图层控制 -->
    <view class="layer-bar">
      <view class="layer-toggle {{showTerrain ? 'layer-on' : ''}}" bindtap="toggleTerrain">地形</view>
      <view class="layer-toggle {{showLowland ? 'layer-on' : ''}}" bindtap="toggleLowland">低洼</view>
      <view class="layer-toggle {{showRiver ? 'layer-on' : ''}}" bindtap="toggleRiver">水系</view>
    </view>

    <map
      class="judge-map"
      latitude="{{mapCenter.latitude}}"
      longitude="{{mapCenter.longitude}}"
      scale="13"
      markers="{{allMarkers}}"
      polygons="{{polygons}}"
      polyline="{{polylines}}"
      show-location
      bindtap="onMapTap"
    ></map>

    <!-- 高程图例 -->
    <view class="elev-legend" wx:if="{{showTerrain}}">
      <text class="elev-legend-title">高程(m)</text>
      <view class="elev-legend-items">
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#08306b;"></view>
          <text>&lt;10</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#1565c0;"></view>
          <text>10-20</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#2196f3;"></view>
          <text>20-30</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#43a047;"></view>
          <text>30-50</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#8bc34a;"></view>
          <text>50-80</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#f9a825;"></view>
          <text>80-120</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#ef6c00;"></view>
          <text>120-200</text>
        </view>
        <view class="elev-legend-item">
          <view class="elev-color-box" style="background:#6d4c41;"></view>
          <text>&gt;200</text>
        </view>
      </view>
    </view>

    <view class="map-legend">
      <text>{{hazards.length}} 个隐患点</text>
      <text wx:if="{{polyPoints.length > 0}}"> | 已圈选约 {{selectedHazardCount}} 个点位</text>
      <text wx:if="{{showLowland}}"> | 红=极低洼(&lt;30m) 橙=低洼(&lt;50m)</text>
    </view>
  </view>

  <!-- 隐患点列表 -->
  <view class="card">
    <view class="card-title" style="display:flex;justify-content:space-between;align-items:center">
      <view>
        <text class="card-title-icon">⚠️</text>
        <text>隐患点概览</text>
      </view>
      <view class="btn btn-sm" style="font-size:12px;padding:4px 12px;margin:0" bindtap="aiAnalyzeHazards">AI智能识别</view>
    </view>
    <view class="hazard-list">
      <view class="hazard-item" wx:for="{{hazards}}" wx:key="name">
        <view class="hazard-name">
          {{item.name}}
          <text wx:if="{{item.ai_risk_score}}" style="color:#dc2626;font-size:11px;margin-left:4px">({{item.ai_risk_score}}分)</text>
        </view>
        <view class="hazard-info">
          <text class="tag {{item.level === '重大' ? 'tag-red' : (item.level === '较大' ? 'tag-orange' : 'tag-blue')}}">{{item.level}}</text>
          <text class="hazard-type">{{item.type}}</text>
          <text class="hazard-elev">{{item.elevation || '--'}}m</text>
        </view>
        <view wx:if="{{item.description}}" class="hazard-desc" style="font-size:11px;color:#94a3b8;margin-top:4px;line-height:1.4">{{item.description}}</view>
      </view>
    </view>
  </view>

  <!-- 开始研判按钮 -->
  <button class="btn btn-primary btn-large" bindtap="startJudge" disabled="{{judging}}">
    {{judging ? '研判中...' : '开始智能研判'}}
  </button>
  <text class="judge-hint" wx:if="{{polyPoints.length < 3 && !regionPath}}">提示：选择行政区域或圈选区域后研判结果更精准</text>
  <text class="judge-hint" wx:if="{{regionPath}}">将以「{{regionPath}}」为研判区域</text>
</view>
