.container { padding: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #0277bd; margin-bottom: 24rpx; padding-left: 12rpx; border-left: 8rpx solid #2196f3; }
.empty { text-align: center; padding: 80rpx 0; color: #90a4ae; font-size: 28rpx; }
.station-card { background: rgba(255,255,255,0.92); border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.station-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.station-name { font-size: 30rpx; font-weight: 700; color: #263238; }
.station-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx; font-weight: 600; }
.badge-normal { background: #e8f5e9; color: #4caf50; }
.badge-warning { background: #fff3e0; color: #ff9800; }
.badge-danger { background: #ffebee; color: #f44336; }
.station-level { display: flex; align-items: baseline; margin-bottom: 12rpx; }
.level-num { font-size: 48rpx; font-weight: 800; color: #0277bd; }
.level-unit { font-size: 26rpx; color: #78909c; margin-left: 6rpx; }
.bar-bg { height: 24rpx; background: #e0f7fa; border-radius: 12rpx; overflow: hidden; margin-bottom: 12rpx; }
.bar-fill { height: 100%; border-radius: 12rpx; transition: width 0.5s; }
.bar-normal { background: linear-gradient(90deg, #4caf50, #81c784); }
.bar-warning { background: linear-gradient(90deg, #ff9800, #ffb74d); }
.bar-danger { background: linear-gradient(90deg, #f44336, #e57373); animation: pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.7} }
.threshold-row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.th-label { font-size: 24rpx; color: #78909c; }
.station-info { font-size: 24rpx; color: #546e7a; }
.station-time { font-size: 22rpx; color: #90a4ae; margin-top: 6rpx; }
.btn-refresh { background: linear-gradient(135deg, #2196f3, #00bcd4); color: #fff; border: none; border-radius: 44rpx; font-size: 30rpx; font-weight: 700; margin-top: 20rpx; }
