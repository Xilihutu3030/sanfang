.header-banner {
  background: linear-gradient(135deg, #0f172a, #1e40af);
  color: #ffffff;
  padding: 48rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 24rpx;
  opacity: 0.8;
}

.weather-grid {
  display: flex;
  flex-wrap: wrap;
}

.weather-item {
  width: 50%;
  padding: 12rpx 0;
}

.weather-item.warning-item {
  width: 100%;
}

.weather-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.weather-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-top: 4rpx;
}

.weather-update {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 12rpx;
  text-align: right;
}

.refresh-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 500;
  padding: 4rpx 16rpx;
  background: #eff6ff;
  border-radius: 8rpx;
}

.quick-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.quick-item {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.quick-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.quick-label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.quick-count {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}
