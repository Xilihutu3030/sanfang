/* ===== 江海安澜 - 首页 ===== */
.header-banner {
  background: linear-gradient(135deg, #0288d1, #00bcd4);
  color: #ffffff;
  padding: 52rpx 32rpx;
  border-radius: 20rpx;
  margin-bottom: 28rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 131, 143, 0.3);
  position: relative;
  overflow: hidden;
}

/* 水波纹装饰 */
.header-banner::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: -10%;
  width: 120%;
  height: 60rpx;
  background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.header-sub {
  font-size: 24rpx;
  opacity: 0.85;
  letter-spacing: 2rpx;
}

.weather-grid {
  display: flex;
  flex-wrap: wrap;
}

.weather-item {
  width: 50%;
  padding: 12rpx 0;
}

.weather-item.warning-item {
  width: 100%;
}

.weather-label {
  display: block;
  font-size: 22rpx;
  color: #78909c;
}

.weather-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0288d1;
  margin-top: 4rpx;
}

.weather-update {
  font-size: 22rpx;
  color: #80deea;
  margin-top: 12rpx;
  text-align: right;
}

.refresh-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #00bcd4;
  font-weight: 600;
  padding: 6rpx 20rpx;
  background: #e0f7fa;
  border-radius: 20rpx;
}

.quick-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.quick-item {
  flex: 1;
  border-radius: 20rpx;
  padding: 36rpx 20rpx;
  text-align: center;
  border: none;
}

.quick-grid .quick-item:first-child {
  background: linear-gradient(160deg, #e0f7fa, #b2ebf2);
  box-shadow: 0 4rpx 20rpx rgba(0, 131, 143, 0.12);
}

.quick-grid .quick-item:last-child {
  background: linear-gradient(160deg, #e0f2f1, #b2dfdb);
  box-shadow: 0 4rpx 20rpx rgba(0, 105, 92, 0.12);
}

.quick-icon {
  display: block;
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  display: block;
  font-size: 26rpx;
  color: #0288d1;
  font-weight: 600;
}

.quick-count {
  display: block;
  font-size: 22rpx;
  color: #26c6da;
  margin-top: 6rpx;
}

/* ===== 高级功能入口 ===== */
.adv-section {
  margin-top: 32rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.08);
  border-top: 6rpx solid #00bcd4;
}

.adv-group-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #0288d1;
  margin-top: 20rpx;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #00bcd4;
  line-height: 1;
}

.adv-group-title:first-child {
  margin-top: 0;
}

.adv-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.adv-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 14rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}

.adv-item:active {
  transform: scale(0.95);
  background: #e0f7fa;
}

.adv-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.adv-label {
  font-size: 24rpx;
  color: #37474f;
  font-weight: 600;
}
