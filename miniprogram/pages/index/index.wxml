<view class="container">
  <!-- 顶部标题 -->
  <view class="header-banner">
    <view class="header-title">智慧三防指挥调度</view>
    <view class="header-sub">防风 · 防汛 · 防旱</view>
  </view>

  <!-- 气象卡片 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">🌤️</text>
      <text>实时气象</text>
      <view class="refresh-btn" bindtap="refreshWeather">刷新</view>
    </view>
    <block wx:if="{{weather}}">
      <view class="weather-grid">
        <view class="weather-item warning-item">
          <text class="weather-label">预警</text>
          <text class="weather-value text-red">{{weather.warning}}</text>
        </view>
        <view class="weather-item">
          <text class="weather-label">1h雨量</text>
          <text class="weather-value">{{weather.rain1h}} mm</text>
        </view>
        <view class="weather-item">
          <text class="weather-label">24h雨量</text>
          <text class="weather-value text-orange">{{weather.rain24h}} mm</text>
        </view>
        <view class="weather-item">
          <text class="weather-label">6h预报</text>
          <text class="weather-value">{{weather.forecast6h}}</text>
        </view>
      </view>
      <view class="weather-update">更新: {{weather.updateTime}}</view>
    </block>
    <block wx:else>
      <view class="empty-state" style="padding: 40rpx 0;">
        <text class="empty-text">气象数据加载中...</text>
      </view>
    </block>
  </view>

  <!-- 快速研判入口 -->
  <button class="btn btn-primary btn-large" bindtap="goJudge">
    开始智能研判
  </button>

  <!-- 最近研判结果 -->
  <view class="card" wx:if="{{lastJudge}}" bindtap="viewLastResult">
    <view class="card-title">
      <text class="card-title-icon">📊</text>
      <text>最近研判结果</text>
      <view class="list-item-arrow" style="margin-left:auto;">查看 ></view>
    </view>
    <view class="risk-badge {{lastJudge._riskClass || 'risk-high'}}" style="margin-bottom:0;">
      <text class="risk-level-text">{{lastJudge['1_综合风险等级']['等级'] || '--'}}</text>
      <text class="risk-sub-text">{{lastJudge['1_综合风险等级']['响应等级'] || ''}} | {{lastJudge['研判时间'] || ''}}</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-grid">
    <view class="quick-item" bindtap="goResources">
      <text class="quick-icon">📦</text>
      <text class="quick-label">应急资源</text>
      <text class="quick-count" wx:if="{{resourceStats}}">{{resourceStats.total}}项</text>
    </view>
    <view class="quick-item" bindtap="goHistory">
      <text class="quick-icon">📋</text>
      <text class="quick-label">历史记录</text>
    </view>
  </view>

  <!-- 功能模块 - 分组排列 -->
  <view class="adv-section">
    <!-- 指挥调度 -->
    <view class="adv-group-title">指挥调度</view>
    <view class="adv-grid">
      <view class="adv-item" bindtap="goPage" data-url="/pages/simulation/simulation">
        <text class="adv-icon">🎯</text>
        <text class="adv-label">情景推演</text>
      </view>
      <view class="adv-item" bindtap="goPage" data-url="/pages/tasks/tasks">
        <text class="adv-icon">📝</text>
        <text class="adv-label">任务派单</text>
      </view>
      <view class="adv-item" bindtap="goPage" data-url="/pages/chat/chat">
        <text class="adv-icon">💬</text>
        <text class="adv-label">AI助手</text>
      </view>
    </view>

    <!-- 监测预警 -->
    <view class="adv-group-title">监测预警</view>
    <view class="adv-grid">
      <view class="adv-item" bindtap="goPage" data-url="/pages/water-monitor/water-monitor">
        <text class="adv-icon">🌊</text>
        <text class="adv-label">水位监测</text>
      </view>
      <view class="adv-item" bindtap="goPage" data-url="/pages/alert-settings/alert-settings">
        <text class="adv-icon">🔔</text>
        <text class="adv-label">预警设置</text>
      </view>
      <view class="adv-item" bindtap="goPage" data-url="/pages/cameras/cameras">
        <text class="adv-icon">📹</text>
        <text class="adv-label">视频监控</text>
      </view>
    </view>

    <!-- 数据管理 -->
    <view class="adv-group-title">数据管理</view>
    <view class="adv-grid">
      <view class="adv-item" bindtap="goPage" data-url="/pages/hazard-editor/hazard-editor">
        <text class="adv-icon">📍</text>
        <text class="adv-label">风险点管理</text>
      </view>
      <view class="adv-item" bindtap="goPage" data-url="/pages/history-compare/history-compare">
        <text class="adv-icon">📊</text>
        <text class="adv-label">灾情对比</text>
      </view>
    </view>

    <!-- 市民上报 -->
    <view class="adv-group-title">市民上报</view>
    <view class="adv-grid">
      <view class="adv-item adv-item-report" bindtap="goPage" data-url="/pages/disaster-report/disaster-report">
        <text class="adv-icon">📸</text>
        <text class="adv-label">灾情上报</text>
      </view>
      <view class="adv-item" bindtap="goPage" data-url="/pages/qrcode-gen/qrcode-gen">
        <text class="adv-icon">📱</text>
        <text class="adv-label">上报二维码</text>
      </view>
    </view>
  </view>
</view>
