.container { padding: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #0277bd; margin-bottom: 20rpx; padding-left: 12rpx; border-left: 8rpx solid #2196f3; }
.card { background: rgba(255,255,255,0.9); border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.form-group { margin-bottom: 20rpx; }
.label { font-size: 26rpx; color: #37474f; font-weight: 600; display: block; margin-bottom: 8rpx; }
.form-group input { background: #e0f7fa; border: 2rpx solid #b2ebf2; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; }
.picker-box { background: #e0f7fa; border: 2rpx solid #b2ebf2; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; display: flex; justify-content: space-between; }
.arrow { color: #00bcd4; font-size: 22rpx; }
.btn-primary { background: linear-gradient(135deg, #2196f3, #00bcd4); color: #fff; border: none; border-radius: 44rpx; padding: 20rpx 0; font-size: 30rpx; font-weight: 700; }
.empty { text-align: center; padding: 40rpx 0; color: #90a4ae; font-size: 28rpx; }
.rule-item { display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.9); padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 12rpx; box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.05); }
.rule-info { flex: 1; font-size: 28rpx; color: #263238; }
.rule-cond { font-weight: 600; }
.rule-op { color: #ff9800; font-weight: 600; }
.rule-notify { color: #78909c; }
.rule-right { display: flex; align-items: center; gap: 16rpx; }
.rule-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; font-weight: 600; }
.rule-status.on { background: #e8f5e9; color: #4caf50; }
.rule-status.off { background: #fafafa; color: #bdbdbd; }
.btn-del { font-size: 24rpx; color: #f44336; font-weight: 600; }
