/* 步骤条 */
.steps-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 60rpx 8rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-active {
  background: #2563eb;
  color: #fff;
}

.step-done {
  background: #059669;
  color: #fff;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e2e8f0;
  margin: 0 12rpx;
}

.line-active {
  background: #059669;
}

.steps-labels {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 40rpx 24rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

/* AI描述 */
.ai-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
}

/* 来源选择网格 */
.source-grid {
  display: flex;
  gap: 20rpx;
  padding: 0 0 24rpx;
}

.source-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #f1f5f9;
}

.source-item:active {
  background: #f8fafc;
  border-color: #2563eb;
}

.source-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.source-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 6rpx;
}

.source-hint {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 提示卡片 */
.tips-card {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 8rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #a16207;
  line-height: 1.8;
}

/* 预览 */
.preview-image {
  width: 100%;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.preview-doc {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.preview-doc-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.preview-doc-name {
  font-size: 28rpx;
  color: #475569;
  word-break: break-all;
  text-align: center;
}

/* 识别中 */
.recognizing-card {
  text-align: center;
  padding: 60rpx 24rpx;
}

.recognizing-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.recognizing-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.recognizing-hint {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 32rpx;
}

.recognizing-dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #2563eb;
  animation: bounce 1.2s infinite ease-in-out;
}

.dot2 {
  animation-delay: 0.2s;
}

.dot3 {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 识别结果 */
.result-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 400;
}

.field-list {
  margin-top: 12rpx;
}

.field-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.field-item:last-child {
  border-bottom: none;
}

.field-label {
  font-size: 26rpx;
  color: #64748b;
  width: 160rpx;
  flex-shrink: 0;
}

.field-value {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  word-break: break-all;
}

.field-confidence {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.confidence-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.conf-high {
  background: #dcfce7;
  color: #166534;
}

.conf-mid {
  background: #fef9c3;
  color: #854d0e;
}

.conf-low {
  background: #fee2e2;
  color: #991b1b;
}

.result-hint {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  padding: 32rpx 0;
}

/* 错误状态 */
.error-card {
  text-align: center;
  padding: 60rpx 24rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #dc2626;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
