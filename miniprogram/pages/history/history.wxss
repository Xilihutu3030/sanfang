.history-item {
  margin-bottom: 20rpx;
}

.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.risk-tag {
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.risk-tag.risk-extreme { background: #dc2626; }
.risk-tag.risk-high { background: #ea580c; }
.risk-tag.risk-mid { background: #d97706; }
.risk-tag.risk-low { background: #2563eb; }

.history-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.history-score {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.history-risks {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
