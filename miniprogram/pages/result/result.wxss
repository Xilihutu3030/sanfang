.risk-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.risk-tags .tag {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
}

.top5-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.top5-item:last-child {
  border-bottom: none;
}

.top5-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  margin-right: 20rpx;
  background: #94a3b8;
}

.rank-1 { background: #dc2626; }
.rank-2 { background: #ea580c; }
.rank-3 { background: #d97706; }

.top5-content {
  flex: 1;
}

.top5-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.top5-info {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.flood-grid {
  display: flex;
}

.flood-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
}

.flood-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.flood-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-top: 6rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.suggestion-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}

.leader-card {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
}

.leader-text {
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.8;
}

.copy-hint {
  margin-left: auto;
  font-size: 22rpx;
  color: #d97706;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-chat {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb) !important;
  color: #fff !important;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
}

/* 应急响应总结报告 */
.response-report-section {
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #cbd5e1;
  text-align: center;
}

.session-count-info {
  font-size: 24rpx;
  color: #78909c;
  margin-bottom: 12rpx;
}

.btn-response-report {
  background: #0277bd !important;
  color: #fff !important;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  width: 100%;
  border-radius: 12rpx;
  padding: 20rpx 0;
}

.btn-response-report[disabled] {
  opacity: 0.6;
}

/* 报告弹窗 */
.report-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-modal-box {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.report-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #e2e8f0;
  background: #f8fafc;
}

.report-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0277bd;
}

.report-modal-close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 0 10rpx;
}

.report-modal-body {
  flex: 1;
  max-height: 60vh;
  padding: 24rpx 30rpx;
}

.report-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #1e293b;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.report-modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  border-top: 2rpx solid #e2e8f0;
  background: #f8fafc;
}
