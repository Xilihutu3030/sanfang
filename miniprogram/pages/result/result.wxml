<view class="container">
  <!-- 风险等级 -->
  <view class="risk-badge {{riskClass}}">
    <text class="risk-level-text">{{riskInfo['等级'] || '--'}}</text>
    <text class="risk-sub-text">{{riskInfo['响应等级'] || ''}} | 得分: {{riskInfo['得分'] || '--'}}</text>
  </view>

  <!-- 主要风险类型 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">🎯</text>
      <text>主要风险类型</text>
    </view>
    <view class="risk-tags">
      <text class="tag tag-red" wx:for="{{mainRisks}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <!-- Top5危险点位 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">🚨</text>
      <text>Top5 最危险点位</text>
    </view>
    <view class="top5-item" wx:for="{{top5}}" wx:key="排名">
      <view class="top5-rank rank-{{item['排名']}}">{{item['排名']}}</view>
      <view class="top5-content">
        <text class="top5-name">{{item['名称']}}</text>
        <text class="top5-info">{{item['类型']}} | {{item['风险分']}}分</text>
      </view>
    </view>
  </view>

  <!-- 淹没预判 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">🌊</text>
      <text>淹没预判</text>
    </view>
    <view class="flood-grid">
      <view class="flood-item">
        <text class="flood-label">淹没面积</text>
        <text class="flood-value">{{flood['可能淹没面积'] || '--'}}</text>
      </view>
      <view class="flood-item">
        <text class="flood-label">积水深度</text>
        <text class="flood-value">{{flood['最大积水深度'] || '--'}}</text>
      </view>
      <view class="flood-item">
        <text class="flood-label">持续时间</text>
        <text class="flood-value">{{flood['灾害持续时间'] || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 指挥建议 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">📢</text>
      <text>指挥建议</text>
    </view>
    <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="index">
      <text class="suggestion-num">{{index + 1}}</text>
      <text class="suggestion-text">{{item}}</text>
    </view>
  </view>

  <!-- 领导汇报 -->
  <view class="card leader-card" bindtap="copyLeaderReport">
    <view class="card-title">
      <text class="card-title-icon">📝</text>
      <text>领导汇报话术</text>
      <text class="copy-hint">点击复制</text>
    </view>
    <view class="leader-text">{{leaderReport}}</view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <button class="btn btn-success" style="flex:1;" bindtap="copyReport">复制简报</button>
    <button class="btn btn-primary" style="flex:1;" bindtap="saveHistory">保存记录</button>
  </view>
  <button class="btn btn-chat" bindtap="goChat">AI智能对话 - 追问研判详情</button>
  <button class="btn btn-outline" open-type="share">分享给同事</button>

  <!-- 应急响应总结报告 -->
  <view class="response-report-section">
    <view class="session-count-info">本次会话已研判 {{sessionCount}} 次</view>
    <button class="btn btn-response-report" bindtap="generateResponseReport" disabled="{{generatingReport}}">
      {{generatingReport ? '生成中...' : '结束响应 & 生成总结报告'}}
    </button>
  </view>

  <!-- 总结报告弹窗 -->
  <view class="report-modal-overlay" wx:if="{{showResponseReport}}" bindtap="closeResponseReport">
    <view class="report-modal-box" catchtap="">
      <view class="report-modal-header">
        <text class="report-modal-title">应急响应总结报告</text>
        <text class="report-modal-close" bindtap="closeResponseReport">×</text>
      </view>
      <scroll-view class="report-modal-body" scroll-y>
        <text class="report-text">{{responseReport}}</text>
      </scroll-view>
      <view class="report-modal-actions">
        <button class="btn btn-success" style="flex:1;" bindtap="copyResponseReport">复制报告</button>
        <button class="btn btn-primary" style="flex:1;" bindtap="confirmEndResponse">确认结束响应</button>
      </view>
    </view>
  </view>
</view>
