.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f172a 0%, #1e3a5f 50%, #0f172a 100%);
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.logo-title {
  font-size: 40rpx;
  color: #e2e8f0;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.logo-sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.login-card {
  width: 100%;
  max-width: 640rpx;
  background: rgba(30, 41, 59, 0.95);
  border: 2rpx solid #334155;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
}

.error-bar {
  background: #fef2f2;
  border: 2rpx solid #fecaca;
  color: #dc2626;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #1e293b;
  border: 2rpx solid #475569;
  border-radius: 12rpx;
  color: #e2e8f0;
  font-size: 28rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #1e293b;
  border: 2rpx solid #475569;
  border-radius: 12rpx;
  color: #e2e8f0;
  font-size: 28rpx;
}

.picker-arrow {
  font-size: 22rpx;
  color: #94a3b8;
}

.login-btn {
  width: 100% !important;
  margin-top: 16rpx;
  padding: 22rpx 0;
  background: linear-gradient(135deg, #2563eb, #1e40af) !important;
  color: #ffffff !important;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.login-btn[disabled] {
  opacity: 0.6;
}

.demo-section {
  margin-top: 36rpx;
  padding: 24rpx;
  background: rgba(37, 99, 235, 0.1);
  border: 2rpx solid rgba(37, 99, 235, 0.2);
  border-radius: 12rpx;
}

.demo-title {
  display: block;
  font-size: 24rpx;
  color: #60a5fa;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.demo-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.demo-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(37, 99, 235, 0.08);
  border-radius: 8rpx;
}

.demo-role {
  font-size: 22rpx;
  color: #93c5fd;
  font-weight: 500;
  min-width: 80rpx;
}

.demo-acc {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: monospace;
}

.login-footer {
  margin-top: 36rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
}
