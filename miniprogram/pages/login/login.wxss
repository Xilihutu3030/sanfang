/* ===== 江海安澜 - 登录页 ===== */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0277bd 0%, #0288d1 30%, #00bcd4 60%, #2196f3 100%);
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.logo-title {
  font-size: 42rpx;
  color: #ffffff;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.logo-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.login-card {
  width: 100%;
  max-width: 640rpx;
  background: rgba(255, 255, 255, 0.92);
  border: none;
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(2, 136, 209, 0.25);
  backdrop-filter: blur(12px);
}

.error-bar {
  background: #ffebee;
  border: 2rpx solid #ffcdd2;
  color: #f44336;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #37474f;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  padding: 22rpx 24rpx;
  background: #e0f7fa;
  border: 2rpx solid #b2ebf2;
  border-radius: 14rpx;
  color: #263238;
  font-size: 28rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 24rpx;
  background: #e0f7fa;
  border: 2rpx solid #b2ebf2;
  border-radius: 14rpx;
  color: #263238;
  font-size: 28rpx;
}

.picker-arrow {
  font-size: 22rpx;
  color: #00bcd4;
}

.login-btn {
  width: 100% !important;
  margin-top: 20rpx;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #0288d1, #00bcd4) !important;
  color: #ffffff !important;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(2, 136, 209, 0.35);
}

.login-btn[disabled] {
  opacity: 0.6;
}

.demo-section {
  margin-top: 36rpx;
  padding: 24rpx;
  background: #e0f7fa;
  border: 2rpx solid #b2ebf2;
  border-radius: 16rpx;
}

.demo-title {
  display: block;
  font-size: 24rpx;
  color: #4caf50;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.demo-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.demo-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 10rpx;
}

.demo-role {
  font-size: 22rpx;
  color: #00bcd4;
  font-weight: 600;
  min-width: 80rpx;
}

.demo-acc {
  font-size: 22rpx;
  color: #37474f;
  font-family: monospace;
}

.login-footer {
  margin-top: 36rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  text-align: center;
}
