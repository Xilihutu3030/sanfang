.container { padding: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #0277bd; margin-bottom: 20rpx; padding-left: 12rpx; border-left: 8rpx solid #2196f3; }
.card { background: rgba(255,255,255,0.92); border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.form-group { margin-bottom: 20rpx; }
.label { font-size: 26rpx; color: #37474f; font-weight: 600; display: block; margin-bottom: 8rpx; }
.form-group input { background: #e0f7fa; border: 2rpx solid #b2ebf2; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(135deg, #2196f3, #00bcd4); color: #fff; border: none; border-radius: 44rpx; padding: 22rpx 0; font-size: 30rpx; font-weight: 700; margin-top: 10rpx; }

/* Canvas */
.canvas-wrap { display: flex; justify-content: center; margin-bottom: 20rpx; border: 2rpx solid #e0e0e0; border-radius: 12rpx; overflow: hidden; }
.qr-canvas { background: #fff; }

/* URL */
.url-box { background: #f5f5f5; border-radius: 10rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; word-break: break-all; }
.url-label { font-size: 24rpx; color: #78909c; font-weight: 600; }
.url-text { font-size: 22rpx; color: #0277bd; }

/* Actions */
.action-btns { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.btn-save { flex: 1; background: linear-gradient(135deg, #f44336, #ff5722); color: #fff; border: none; border-radius: 44rpx; font-size: 28rpx; font-weight: 700; padding: 18rpx 0; }
.btn-copy { flex: 1; background: #e0f7fa; color: #0277bd; border: 2rpx solid #80deea; border-radius: 44rpx; font-size: 28rpx; font-weight: 600; padding: 18rpx 0; }

/* Tips */
.tips { background: #f0fdfa; border-radius: 12rpx; padding: 20rpx 24rpx; }
.tips-title { font-size: 26rpx; font-weight: 700; color: #0277bd; margin-bottom: 10rpx; }
.tip-item { font-size: 24rpx; color: #546e7a; margin-bottom: 6rpx; padding-left: 8rpx; }
