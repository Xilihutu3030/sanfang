<view class="container">
  <!-- 说明 -->
  <view class="card">
    <view class="card-title">
      <text class="card-title-icon">📥</text>
      <text>批量导入{{typeLabel}}</text>
    </view>
    <view class="import-steps">
      <view class="step-item">
        <text class="step-num">1</text>
        <text class="step-text">下载导入模板，按格式填写数据</text>
      </view>
      <view class="step-item">
        <text class="step-num">2</text>
        <text class="step-text">点击"选择文件"上传 Excel/CSV</text>
      </view>
      <view class="step-item">
        <text class="step-num">3</text>
        <text class="step-text">系统自动解析并导入数据</text>
      </view>
    </view>
  </view>

  <!-- 操作 -->
  <button class="btn btn-outline" bindtap="downloadTemplate">📄 下载导入模板</button>
  <button class="btn btn-primary btn-large" bindtap="chooseFile" disabled="{{importing}}" style="margin-top:20rpx;">
    {{importing ? '📤 导入中...' : '📂 选择文件上传'}}
  </button>

  <!-- 导入结果 -->
  <view class="card" wx:if="{{result}}" style="margin-top:24rpx;">
    <view class="card-title">
      <text class="card-title-icon">📊</text>
      <text>导入结果</text>
    </view>
    <view class="result-file">文件: {{result.fileName || '--'}}</view>
    <view class="result-grid">
      <view class="result-item">
        <text class="result-value text-green">{{result.imported}}</text>
        <text class="result-label">成功导入</text>
      </view>
      <view class="result-item">
        <text class="result-value text-red">{{result.failed}}</text>
        <text class="result-label">导入失败</text>
      </view>
    </view>

    <!-- 错误详情 -->
    <block wx:if="{{result.errors && result.errors.length > 0}}">
      <view class="divider"></view>
      <view class="error-title">失败详情:</view>
      <view class="error-item" wx:for="{{result.errors}}" wx:key="row">
        <text class="text-red">第{{item.row}}行:</text> {{item.reason}}
      </view>
    </block>

    <button class="btn btn-primary" bindtap="goBack" style="margin-top:20rpx;">返回资源列表</button>
  </view>
</view>
