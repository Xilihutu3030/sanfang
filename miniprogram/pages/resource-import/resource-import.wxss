.import-steps {
  padding: 8rpx 0;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #475569;
}

.result-file {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
}

.result-grid {
  display: flex;
}

.result-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
}

.result-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}

.result-label {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.error-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #dc2626;
  margin-bottom: 8rpx;
}

.error-item {
  font-size: 24rpx;
  color: #64748b;
  padding: 6rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
