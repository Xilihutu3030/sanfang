.container { padding: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #0277bd; margin-bottom: 24rpx; padding-left: 12rpx; border-left: 8rpx solid #2196f3; }

/* 统计 */
.stats-row { font-size: 26rpx; color: #78909c; margin-bottom: 16rpx; }

/* 筛选 */
.filter-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.filter-btn { background: rgba(255,255,255,0.92); padding: 14rpx 24rpx; border-radius: 12rpx; font-size: 26rpx; color: #263238; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }

/* 摄像头卡片 */
.cam-card { background: rgba(255,255,255,0.92); border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.cam-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.cam-name-row { display: flex; align-items: center; flex: 1; min-width: 0; }
.cam-name { font-size: 30rpx; font-weight: 700; color: #263238; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.status-dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-right: 12rpx; flex-shrink: 0; }
.cam-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx; font-weight: 600; flex-shrink: 0; margin-left: 12rpx; }
.badge-traffic { background: #eff6ff; color: #3b82f6; }
.badge-water { background: #ecfeff; color: #06b6d4; }
.badge-flood { background: #fff7ed; color: #f59e0b; }
.badge-scenic { background: #ecfdf5; color: #10b981; }
.badge-public { background: #f5f3ff; color: #8b5cf6; }
.badge-other { background: #f9fafb; color: #6b7280; }
.cam-meta { font-size: 24rpx; color: #78909c; display: flex; justify-content: space-between; margin-bottom: 14rpx; }
.cam-status { color: #10b981; }
.cam-actions { display: flex; gap: 12rpx; }
.cam-btn { flex: 1; text-align: center; padding: 12rpx 0; border-radius: 10rpx; font-size: 26rpx; font-weight: 600; }
.cam-btn-play { background: linear-gradient(135deg, #2196f3, #00bcd4); color: #fff; }
.cam-btn-loc { background: #e0f7fa; color: #0277bd; }
.cam-btn-del { background: #ffebee; color: #f44336; }

/* 视频浮层 */
.video-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; justify-content: center; align-items: center; }
.video-box { width: 92%; background: #fff; border-radius: 20rpx; overflow: hidden; }
.video-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: linear-gradient(135deg, #0277bd, #00bcd4); }
.video-title { font-size: 30rpx; font-weight: 600; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; }
.video-close { font-size: 36rpx; color: #fff; padding: 0 12rpx; opacity: 0.8; }
.video-info { padding: 16rpx 24rpx; }
.video-info-row { display: flex; align-items: center; margin-bottom: 6rpx; }
.video-source { font-size: 26rpx; color: #263238; }
.video-meta { font-size: 24rpx; color: #78909c; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 0; color: #90a4ae; font-size: 28rpx; }

/* 添加区域 */
.add-section { margin-top: 20rpx; margin-bottom: 20rpx; }
.add-toggle { text-align: center; padding: 20rpx; background: rgba(255,255,255,0.92); border-radius: 16rpx; font-size: 30rpx; font-weight: 600; color: #0277bd; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.add-form { background: rgba(255,255,255,0.92); border-radius: 16rpx; padding: 24rpx; margin-top: 16rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.form-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.form-group { flex: 1; }
.form-full { margin-bottom: 16rpx; }
.form-label { font-size: 24rpx; color: #546e7a; margin-bottom: 6rpx; display: block; font-weight: 600; }
.form-input { background: #f1f5f9; padding: 16rpx; border-radius: 10rpx; font-size: 26rpx; width: 100%; box-sizing: border-box; }
.picker-display { color: #263238; }
.form-btns { display: flex; gap: 16rpx; margin-top: 20rpx; }
.btn-save { flex: 1; background: linear-gradient(135deg, #2196f3, #00bcd4) !important; color: #fff !important; border: none; border-radius: 44rpx; font-size: 28rpx; font-weight: 700; }
.btn-pick { flex: 1; background: #e0f7fa !important; color: #0277bd !important; border: none; border-radius: 44rpx; font-size: 28rpx; font-weight: 700; }

/* 刷新按钮 */
.btn-refresh { background: linear-gradient(135deg, #2196f3, #00bcd4); color: #fff; border: none; border-radius: 44rpx; font-size: 30rpx; font-weight: 700; margin-top: 20rpx; }
