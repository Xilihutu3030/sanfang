.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.resource-item:last-child {
  border-bottom: none;
}

.resource-main {
  flex: 1;
}

.resource-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.resource-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.resource-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.delete-btn {
  font-size: 22rpx;
  color: #dc2626;
  padding: 4rpx 12rpx;
}
