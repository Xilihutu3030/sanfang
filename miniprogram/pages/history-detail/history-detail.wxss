.time-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #f0f9ff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #2563eb;
}

.time-label {
  font-size: 24rpx;
  color: #64748b;
}

.time-value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
}

.risk-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.risk-tags .tag {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
}

.top5-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.top5-item:last-child {
  border-bottom: none;
}

.top5-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  margin-right: 20rpx;
  background: #94a3b8;
}

.rank-1 { background: #dc2626; }
.rank-2 { background: #ea580c; }
.rank-3 { background: #d97706; }

.top5-content {
  flex: 1;
}

.top5-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
}

.top5-info {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.flood-grid {
  display: flex;
}

.flood-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
}

.flood-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
}

.flood-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-top: 6rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.suggestion-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.6;
}

.leader-card {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
}

.leader-text {
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.8;
}

.copy-hint {
  margin-left: auto;
  font-size: 22rpx;
  color: #d97706;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-chat {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #7c3aed, #2563eb) !important;
  color: #fff !important;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-danger-outline {
  margin-top: 20rpx;
  background: #fff !important;
  color: #dc2626 !important;
  border: 2rpx solid #fca5a5 !important;
  font-size: 26rpx;
}
