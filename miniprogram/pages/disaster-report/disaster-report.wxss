.container { padding: 24rpx; padding-bottom: 60rpx; }

/* Tab */
.tab-bar { display: flex; background: rgba(255,255,255,0.95); border-radius: 16rpx; overflow: hidden; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.1); }
.tab-item { flex: 1; text-align: center; padding: 22rpx 0; font-size: 30rpx; font-weight: 600; color: #78909c; transition: all 0.2s; }
.tab-item.active { color: #0277bd; background: #e0f7fa; border-bottom: 6rpx solid #00bcd4; }

/* Card */
.card { background: rgba(255,255,255,0.92); border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(2,136,209,0.08); }
.section-title { font-size: 32rpx; font-weight: 700; color: #0277bd; margin-bottom: 20rpx; padding-left: 12rpx; border-left: 8rpx solid #2196f3; }

/* Form */
.form-group { margin-bottom: 20rpx; }
.form-row { display: flex; gap: 16rpx; }
.half { flex: 1; }
.label { font-size: 26rpx; color: #37474f; font-weight: 600; display: block; margin-bottom: 8rpx; }
.form-group input { background: #e0f7fa; border: 2rpx solid #b2ebf2; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
.form-group textarea { background: #e0f7fa; border: 2rpx solid #b2ebf2; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; width: 100%; min-height: 120rpx; box-sizing: border-box; }
.picker-box { background: #e0f7fa; border: 2rpx solid #b2ebf2; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; display: flex; justify-content: space-between; }
.arrow { color: #00bcd4; font-size: 22rpx; }
.sev-2 { color: #ef4444; }
.sev-3 { color: #dc2626; font-weight: 700; }

/* Location */
.loc-btns { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.btn-loc { flex: 1; background: #e0f7fa; color: #0277bd; border: 2rpx solid #80deea; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; padding: 18rpx 0; text-align: center; }
.btn-loc-pick { background: #fff3e0; color: #ff9800; border-color: #ffcc80; }
.loc-info { background: #e8f5e9; border-radius: 10rpx; padding: 16rpx 20rpx; }
.loc-coord { font-size: 26rpx; color: #2e7d32; font-family: monospace; }
.loc-addr { display: block; font-size: 24rpx; color: #558b2f; margin-top: 4rpx; }
.loc-empty { text-align: center; color: #90a4ae; font-size: 26rpx; padding: 20rpx 0; }

/* Media Grid */
.media-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.media-item { width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; position: relative; }
.media-item image { width: 100%; height: 100%; }
.media-del { position: absolute; top: 4rpx; right: 4rpx; width: 36rpx; height: 36rpx; background: rgba(244,67,54,0.85); color: #fff; border-radius: 50%; text-align: center; line-height: 36rpx; font-size: 22rpx; }
.media-badge { position: absolute; bottom: 4rpx; left: 4rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }
.media-add { width: 160rpx; height: 160rpx; border: 3rpx dashed #b2ebf2; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f0fdfa; }
.media-add-video { border-color: #ffcc80; background: #fffbeb; }
.add-icon { font-size: 48rpx; color: #00bcd4; line-height: 1; }
.media-add-video .add-icon { color: #ff9800; }
.add-text { font-size: 22rpx; color: #78909c; margin-top: 4rpx; }
.media-tip { font-size: 22rpx; color: #90a4ae; margin-top: 12rpx; }

/* Submit Button */
.btn-submit { background: linear-gradient(135deg, #f44336, #ff5722); color: #fff; border: none; border-radius: 44rpx; padding: 24rpx 0; font-size: 32rpx; font-weight: 700; margin-top: 20rpx; width: 100%; }
.btn-submit[disabled] { opacity: 0.6; }

/* Stats */
.stats-bar { display: flex; background: rgba(255,255,255,0.92); border-radius: 16rpx; padding: 20rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #263238; display: block; }
.stat-pending { color: #f59e0b; }
.stat-verified { color: #10b981; }
.stat-label { font-size: 22rpx; color: #78909c; }

/* Filter */
.filter-bar { margin-bottom: 16rpx; }
.filter-btn { background: #e0f7fa; color: #0277bd; padding: 12rpx 24rpx; border-radius: 10rpx; font-size: 26rpx; display: inline-block; }

/* Report Item */
.report-item { background: rgba(255,255,255,0.92); border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.rpt-header { display: flex; align-items: center; gap: 10rpx; margin-bottom: 10rpx; }
.rpt-sev { font-size: 22rpx; padding: 2rpx 14rpx; border-radius: 6rpx; font-weight: 700; }
.sev-low { background: #dbeafe; color: #3b82f6; }
.sev-medium { background: #fef3c7; color: #f59e0b; }
.sev-high { background: #fee2e2; color: #ef4444; }
.sev-critical { background: #fecaca; color: #dc2626; }
.rpt-type { font-size: 22rpx; color: #64748b; background: #f1f5f9; padding: 2rpx 12rpx; border-radius: 6rpx; }
.rpt-time { font-size: 22rpx; color: #94a3b8; margin-left: auto; }
.rpt-title { font-size: 30rpx; font-weight: 700; color: #1e293b; margin-bottom: 6rpx; }
.rpt-desc { font-size: 26rpx; color: #475569; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.rpt-loc { font-size: 24rpx; color: #64748b; margin-bottom: 8rpx; }
.rpt-media { display: flex; gap: 8rpx; margin: 10rpx 0; }
.rpt-thumb { width: 120rpx; height: 90rpx; border-radius: 8rpx; }
.rpt-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 10rpx; }
.rpt-user { font-size: 24rpx; color: #94a3b8; }
.rpt-actions { display: flex; align-items: center; gap: 10rpx; }
.rpt-upvotes { font-size: 24rpx; color: #10b981; font-weight: 600; }
.btn-upvote { background: #ecfdf5; color: #10b981; border: 2rpx solid #a7f3d0; font-size: 24rpx; padding: 0 20rpx; border-radius: 8rpx; line-height: 2; }

.empty { text-align: center; padding: 60rpx 0; color: #90a4ae; font-size: 28rpx; }
