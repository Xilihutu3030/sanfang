.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: linear-gradient(180deg, #f0fbff 0%, #e0f7fa 100%);
  border-top: 1rpx solid #b2ebf2;
  box-shadow: 0 -4rpx 16rpx rgba(2, 136, 209, 0.08);
  position: relative;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  transition: all 0.3s;
}

.tab-icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
  transition: all 0.3s;
}

.tab-icon-wrap.tab-icon-active {
  width: 68rpx;
  height: 68rpx;
  transform: translateY(-8rpx);
}

.tab-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  opacity: 0.18;
}

.tab-icon {
  font-size: 36rpx;
  position: relative;
  z-index: 1;
}

.tab-icon-active .tab-icon {
  font-size: 42rpx;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  transition: color 0.3s;
}

.tab-item.active .tab-text {
  font-weight: 700;
  font-size: 22rpx;
}

/* 选中指示条 */
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

/* 各 tab 底部指示条颜色由 JS 控制，这里用 nth-child */
.tab-item:nth-child(1).active::after {
  background: linear-gradient(90deg, #2196f3, #64b5f6);
}
.tab-item:nth-child(2).active::after {
  background: linear-gradient(90deg, #ff9800, #ffb74d);
}
.tab-item:nth-child(3).active::after {
  background: linear-gradient(90deg, #4caf50, #81c784);
}
.tab-item:nth-child(4).active::after {
  background: linear-gradient(90deg, #7c4dff, #b388ff);
}
