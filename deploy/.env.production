# 三防指挥系统 - 生产环境配置
# 复制此文件到 /opt/sanfang/.env 并修改

# ===== 运行模式 =====
FLASK_ENV=production

# ===== 密钥（务必修改为随机字符串） =====
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

# ===== LLM 配置 =====
# 模式: rule(纯规则引擎) / hybrid(规则+LLM增强) / llm(纯LLM)
LLM_MODE=rule

# 启用大模型对话功能（hybrid/llm 模式需要）
# ENABLE_LLM=true
# DASHSCOPE_API_KEY=sk-your-dashscope-api-key
